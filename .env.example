# ── Backend API ────────────────────────────────────────────────────────────────
# Point this to your AWS Elastic Beanstalk / ECS / App Runner URL in production
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ── AWS Amplify (set these in the Amplify Console environment variables) ───────
NEXT_PUBLIC_AWS_REGION=eu-west-2
NEXT_PUBLIC_COGNITO_USER_POOL_ID=eu-west-2_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=your_cognito_client_id

# ── Stripe (public key only - secret key lives in backend) ────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://medicalexamucat.co.uk
